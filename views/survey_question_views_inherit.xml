<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================
             Form view (question and section): LSP Workflow header + Tipe Soal
             ============================================================ -->
        <record id="survey_question_form_inherit_lsp_workflow" model="ir.ui.view">
            <field name="name">survey.question.form.inherit.lsp.workflow</field>
            <field name="model">survey.question</field>
            <field name="inherit_id" ref="survey.survey_question_form"/>
            <field name="arch" type="xml">
                <!-- Workflow header buttons -->
                <xpath expr="//sheet" position="before">
                    <header>
                        <button name="action_submit" type="object" string="Ajukan Validasi"
                                class="btn-primary"
                                invisible="state not in ['draft', 'revise'] or not can_submit"/>
                        <button name="action_approve" type="object" string="Setujui (Active)"
                                class="btn-primary"
                                invisible="not can_approve or state == 'active'"/>
                        <button name="action_revise" type="object" string="Minta Revisi"
                                invisible="state != 'waiting' or not can_approve"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,waiting,revise,active"/>
                    </header>
                </xpath>

                <!-- Sembunyikan question_type native (sudah diwakili lsp_question_type) -->
                <xpath expr="//field[@name='question_type']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <!-- Tambah field LSP setelah question_type agar masuk dalam group form -->
                <xpath expr="//field[@name='question_type']" position="after">
                    <field name="unit_code" string="Kode Unit"
                           placeholder="Contoh: TIK.PR01.001.01"
                           invisible="not is_page"/>
                    <field name="lsp_question_type" string="Tipe Soal"
                           invisible="is_page"/>
                    <field name="asesor_id" readonly="1" invisible="is_page"/>
                    <field name="tanggal_dibuat" invisible="is_page"/>
                    <field name="expiry_date" invisible="1"/>
                    <field name="days_until_expiry" invisible="1"/>
                    <field name="is_expired" invisible="1"/>
                    <field name="expiry_info" invisible="is_page" decoration-danger="is_expired"/>
                    <field name="catatan_admin" string="Catatan Admin"
                           invisible="state != 'revise' and not catatan_admin"/>
                    <field name="can_submit" invisible="1"/>
                    <field name="can_approve" invisible="1"/>
                </xpath>
            </field>
        </record>

        <!-- ============================================================
             List/Tree view standalone: Kode Unit + Tipe Soal + Status
             ============================================================ -->
        <record id="survey_question_tree_inherit_lsp_state" model="ir.ui.view">
            <field name="name">survey.question.tree.inherit.lsp.state</field>
            <field name="model">survey.question</field>
            <field name="inherit_id" ref="survey.survey_question_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='title']" position="after">
                    <field name="unit_code" string="Kode Unit" optional="show" invisible="not is_page"/>
                    <field name="lsp_question_type" string="Tipe Soal" optional="show" invisible="is_page"/>
                    <field name="tanggal_dibuat" optional="hide" invisible="is_page"/>
                    <field name="is_expired" column_invisible="True"/>
                    <field name="expiry_info" string="Masa Berlaku" optional="show" invisible="is_page" decoration-danger="is_expired"/>
                    <field name="state" string="Status" decoration-danger="is_expired and not is_page"/>
                </xpath>
            </field>
        </record>

        <!-- ============================================================
             Survey form: inline list soal
             Sembunyikan kolom Question Type native, tampilkan Tipe Soal LSP
             ============================================================ -->
        <record id="survey_survey_view_form_inherit_lsp_question_columns" model="ir.ui.view">
            <field name="name">survey.survey.form.inherit.lsp.question.columns</field>
            <field name="model">survey.survey</field>
            <field name="inherit_id" ref="survey.survey_survey_view_form"/>
            <field name="arch" type="xml">
                <!-- Sembunyikan kolom question_type native di inline list -->
                <xpath expr="//field[@name='question_and_page_ids']/list/field[@name='question_type']" position="attributes">
                    <attribute name="column_invisible">1</attribute>
                </xpath>

                <!-- Tambah kolom LSP di inline list -->
                <xpath expr="//field[@name='question_and_page_ids']/list/field[@name='title']" position="after">
                    <field name="unit_code" string="Kode Unit" optional="show" invisible="not is_page"/>
                    <field name="lsp_question_type" string="Tipe Soal" optional="show" invisible="is_page"/>
                    <field name="tanggal_dibuat" optional="hide" invisible="is_page"/>
                    <field name="is_expired" column_invisible="True"/>
                    <field name="expiry_info" string="Masa Berlaku" optional="show" invisible="is_page" decoration-danger="is_expired"/>
                    <field name="state" string="Status" optional="show" decoration-danger="is_expired and not is_page"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
